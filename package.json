{
  "name": "desktop-char",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite apps/desktop --config apps/desktop/vite.config.ts --open",
    "dev": "vite apps/desktop --config apps/desktop/vite.config.ts",
    "build": "vite build apps/desktop --config apps/desktop/vite.config.ts",
    "preview": "vite preview apps/desktop --config apps/desktop/vite.config.ts --open",
    "test:smoke": "npm run build && node scripts/smoke.mjs",
    "diagnose:tts": "node --experimental-strip-types scripts/tts-diagnostic.ts",
    "test": "node --experimental-strip-types --test packages/*/test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.9.0",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "@pixi/interaction": "^6.5.10",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10"
  },
  "overrides": {
    "gh-pages": "6.2.0"
  }
}
