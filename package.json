{
  "name": "desktop-char",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node scripts/start-web.mjs",
    "desktop": "npm run build && electron apps/desktop/electron/main.mjs",
    "dev": "node scripts/start-web.mjs --no-open",
    "build": "vite build apps/desktop --config apps/desktop/vite.config.ts",
    "preview": "npm run build && node scripts/start-web.mjs --preview",
    "performance:bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File performance-model-service/bootstrap.ps1",
    "performance:start": "powershell -NoProfile -ExecutionPolicy Bypass -File performance-model-service/start.ps1",
    "performance:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File performance-model-service/smoke-test.ps1",
    "tts:local-mcp": "node local-tts-mcp/server.mjs",
    "test:smoke": "npm run build && node scripts/smoke.mjs",
    "test:desktop": "node --test apps/desktop/electron/*.test.mjs",
    "test:local-mcp": "node --test local-tts-mcp/*.test.mjs",
    "test:native": "node scripts/run-koffi-electron-test.mjs",
    "test:desktop-smoke": "npm run build && node scripts/desktop-smoke.mjs",
    "diagnose:tts": "node --experimental-strip-types scripts/tts-diagnostic.ts",
    "diagnose:performance": "node --experimental-strip-types scripts/performance-diagnostic.ts",
    "diagnose:managed-exit": "npm run build && node scripts/managed-performance-exit-diagnostic.mjs",
    "diagnose:drag": "npm run build && node scripts/drag-compositor-diagnostic.mjs",
    "test": "node --experimental-strip-types --test packages/*/test/*.test.ts && npm run test:local-mcp && npm run test:desktop",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test && npm run test:native && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "electron": "^43.1.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.9.0",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pixi/interaction": "^6.5.10",
    "@pixi/unsafe-eval": "^6.5.10",
    "koffi": "^3.1.1",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "zod": "^4.4.3"
  },
  "overrides": {
    "gh-pages": "6.2.0"
  }
}
