{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://desktopchar.local/schemas/desktop-char.character.schema.json",
  "title": "DesktopChar Character Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "model",
    "defaultEmotion",
    "allowedEmotions",
    "allowedActions",
    "expressionCooldownMs",
    "idleReturnDelayMs",
    "gazeProfile",
    "lipSyncProfile"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "model": { "$ref": "#/$defs/relativeAssetPath" },
    "defaultEmotion": { "$ref": "#/$defs/emotion" },
    "allowedEmotions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/emotion" }
    },
    "allowedActions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/action" }
    },
    "emotionBindings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "neutral": { "$ref": "#/$defs/emotionBinding" },
        "happy": { "$ref": "#/$defs/emotionBinding" },
        "sad": { "$ref": "#/$defs/emotionBinding" },
        "angry": { "$ref": "#/$defs/emotionBinding" },
        "surprised": { "$ref": "#/$defs/emotionBinding" },
        "thinking": { "$ref": "#/$defs/emotionBinding" }
      }
    },
    "expressionCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision", "defaultExpressionKey", "descriptors", "bindings"],
      "properties": {
        "revision": { "type": "integer", "minimum": 0 },
        "defaultExpressionKey": { "$ref": "#/$defs/expressionKey" },
        "descriptors": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/expressionDescriptor" }
        },
        "bindings": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "$ref": "#/$defs/expressionKey" },
          "additionalProperties": { "$ref": "#/$defs/expressionBinding" }
        }
      }
    },
    "expressionCooldownMs": { "type": "number", "minimum": 0 },
    "idleReturnDelayMs": { "type": "number", "minimum": 0 },
    "gazeProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headX", "headY", "eyeX", "eyeY"],
      "properties": {
        "headX": { "$ref": "#/$defs/gazeAxis" },
        "headY": { "$ref": "#/$defs/gazeAxis" },
        "eyeX": { "$ref": "#/$defs/gazeAxis" },
        "eyeY": { "$ref": "#/$defs/gazeAxis" },
        "smoothing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["headResponseMs", "eyeResponseMs"],
          "properties": {
            "headResponseMs": { "type": "number", "minimum": 0 },
            "eyeResponseMs": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "lipSyncProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gain"],
      "properties": {
        "gain": { "type": "number", "exclusiveMinimum": 0 },
        "attackMs": { "type": "number", "minimum": 0 },
        "releaseMs": { "type": "number", "minimum": 0 },
        "peakHoldMs": { "type": "number", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "relativeAssetPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![/\\\\])(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"
    },
    "emotion": {
      "enum": ["neutral", "happy", "sad", "angry", "surprised", "thinking"]
    },
    "emotionBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expression"],
      "properties": {
        "expression": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    },
    "expressionKey": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9._-]*[a-z0-9])?$"
    },
    "expressionBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expression"],
      "properties": {
        "expression": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    },
    "affectPrototype": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "valence": { "type": "number", "minimum": -1, "maximum": 1 },
        "arousal": { "type": "number", "minimum": 0, "maximum": 1 },
        "approval": { "type": "number", "minimum": -1, "maximum": 1 },
        "engagement": { "type": "number", "minimum": 0, "maximum": 1 },
        "certainty": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "expressionDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expressionKey",
        "label",
        "semanticTags",
        "prototypeTexts",
        "baseWeight",
        "cooldownMs",
        "holdMs",
        "compatibleAvatarStates"
      ],
      "properties": {
        "expressionKey": { "$ref": "#/$defs/expressionKey" },
        "label": { "type": "string", "minLength": 1 },
        "semanticTags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "prototypeTexts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "affectPrototype": { "$ref": "#/$defs/affectPrototype" },
        "baseWeight": { "type": "number", "exclusiveMinimum": 0 },
        "cooldownMs": { "type": "number", "minimum": 0 },
        "holdMs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minMs", "maxMs"],
          "properties": {
            "minMs": { "type": "number", "minimum": 0 },
            "maxMs": { "type": "number", "minimum": 0 }
          }
        },
        "compatibleAvatarStates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["idle", "listening", "thinking", "speaking", "presenting"]
          }
        }
      }
    },
    "action": { "enum": ["nod", "shake", "tap", "greet"] },
    "direction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["limit", "exponent"],
      "properties": {
        "limit": { "type": "number" },
        "exponent": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "gazeAxis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["negative", "positive", "deadZone"],
      "properties": {
        "negative": { "$ref": "#/$defs/direction" },
        "positive": { "$ref": "#/$defs/direction" },
        "deadZone": { "type": "number", "minimum": 0, "exclusiveMaximum": 1 }
      }
    }
  }
}
