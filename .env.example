# DesktopChar does not automatically load this file. It documents process-level
# bootstrap/diagnostic values and legacy compatibility only. User settings belong
# in desktop-char.config.json; asset calibration belongs in DesktopChar.character.json.

# Application config bootstrap (the legacy name remains accepted during migration).
# DESKTOP_CHAR_CONFIG_PATH=C:\path\to\desktop-char.config.json
# DESKTOP_CHAR_MCP_CONFIG_PATH=C:\path\to\desktop-char.config.json

# Development and native-window diagnostics.
# DESKTOP_CHAR_DEV_URL=http://127.0.0.1:5173
# DESKTOP_CHAR_DRAG_WINDOW_API=auto

# Standalone local-tts-mcp / browser fixture process startup.
DESKTOP_CHAR_TTS_LOCAL_MCP_HOST=127.0.0.1
DESKTOP_CHAR_TTS_LOCAL_MCP_PORT=8766
DESKTOP_CHAR_TTS_LOCAL_DELAY_MS=15
DESKTOP_CHAR_TTS_LOCAL_RATE=1
DESKTOP_CHAR_TTS_LOCAL_CHAR_MS=232
DESKTOP_CHAR_TTS_LOCAL_MIN_MS=500
DESKTOP_CHAR_TTS_SAMPLE_RATE_HZ=24000
DESKTOP_CHAR_TTS_CHANNELS=1

# Legacy desktop application fallbacks. Prefer desktop-char.config.json.
# DESKTOP_CHAR_DRAG_HOLD_DELAY_MS=180
# DESKTOP_CHAR_AGENT_PORT=17373
# DESKTOP_CHAR_TTS_MODE=mcp
# DESKTOP_CHAR_TTS_MCP_ENABLED=true
# DESKTOP_CHAR_TTS_MCP_URL=http://127.0.0.1:8766/mcp
# DESKTOP_CHAR_TTS_MCP_TOOL=tts_open_stream
# DESKTOP_CHAR_TTS_MCP_CANCEL_TOOL=tts_cancel_synthesis
# DESKTOP_CHAR_TTS_TIMEOUT_MS=30000
# DESKTOP_CHAR_TTS_REQUEST_ID_ARGUMENT=request_id
# DESKTOP_CHAR_TTS_TEXT_ARGUMENT=text
# DESKTOP_CHAR_TTS_FORMAT=pcm_s16le
# DESKTOP_CHAR_TTS_VOICE=
# DESKTOP_CHAR_CHARACTER_MCP_ENABLED=true
# DESKTOP_CHAR_CHARACTER_MCP_HOST=127.0.0.1
# DESKTOP_CHAR_CHARACTER_MCP_PORT=17374
# DESKTOP_CHAR_CHARACTER_MCP_PATH=/mcp
